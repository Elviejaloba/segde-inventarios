# Bridge destination
TARGET_BASE_URL=http://localhost:5000
BRIDGE_API_KEY=replace-with-same-key-as-server

# SQL Server (Tango)
TANGO_SERVER=tangoserver
TANGO_DATABASE=crisa_real1
